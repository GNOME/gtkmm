  (c-name "gtk_accelerator_get_label")
  (return-type "char*")
  (parameters
    '("guint" "accelerator_key")
    '("GdkModifierType" "accelerator_mods")
  )
)

(define-function gtk_accelerator_get_label_with_keycode
  (c-name "gtk_accelerator_get_label_with_keycode")
